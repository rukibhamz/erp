# Application environment (copy to .env and customize; never commit .env)
# Existing deployments: secrets are auto-migrated from config.php on first request after pull.
APP_INSTALLED=true
APP_ENV=development
APP_BASE_URL=http://localhost/newerp/

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=erp
DB_PREFIX=erp_

# Application encryption key (generate: php -r "echo bin2hex(random_bytes(32));")
APP_ENCRYPTION_KEY=

# Optional: dedicated MySQL user for backup restore (recommended in production)
# DB_RESTORE_USER=erp_restore
# DB_RESTORE_PASSWORD=
